{
  "name": "otty-v2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:liff": "node ./scripts/dev-liff.mjs",
    "db:backfill:user-profile-fields": "node ./scripts/backfill-user-profile-fields.mjs",
    "db:backfill:working-experiences": "node ./scripts/backfill-working-experiences.mjs",
    "db:normalize:current-site": "node ./scripts/normalize-current-site.mjs",
    "dev:web": "npm run dev --workspace @otty/web",
    "dev:api": "npm run dev --workspace @otty/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
