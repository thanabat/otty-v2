## Runtime env for apps/api
## Copy this file to apps/api/.env.local and fill in the real values.

NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/otty-v2
JWT_SECRET=replace-me
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
WEB_URL=http://localhost:3000
## Comma-separated extra origins for local tools such as LIFF CLI proxy
WEB_URLS=https://localhost:9000
